<!-- PRINT.BZH Page Devis Temporaire v1.0 -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap">
<style>
:root{--bg:#F6F3EE;--card:#EDEAE3;--ink:#008020;--ink-dark:#005C17;--muted:#7A756C;--dark:#1E1C1A;--white:#FFFFFF;--radius:24px;--radius-sm:12px;--border:rgba(0,128,32,0.12);--shadow:0 4px 32px rgba(0,0,0,0.08)}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:Outfit,sans-serif;background:var(--bg);color:var(--dark);font-size:16px;line-height:1.6}
.pbzh{min-height:100vh;display:flex;flex-direction:column}
.pbzh-header{position:fixed;top:0;left:0;right:0;z-index:100;padding:0 48px;height:72px;display:flex;align-items:center;justify-content:space-between;background:rgba(246,243,238,0.95);backdrop-filter:blur(20px);border-bottom:1px solid var(--border)}
.pbzh-logo{font-family:Outfit,sans-serif;font-size:20px;font-weight:800;letter-spacing:-0.02em;color:var(--ink);text-decoration:none}
.pbzh-logo span{opacity:0.4;font-weight:600;margin:0 4px}
.pbzh-header-tag{font-size:11px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted);background:var(--card);padding:6px 14px;border-radius:100px;border:1px solid var(--border)}
.pbzh-hero{margin-top:72px;padding:80px 48px 0;display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:start;max-width:1400px;margin-left:auto;margin-right:auto}
.pbzh-eyebrow{display:inline-flex;align-items:center;gap:8px;margin-bottom:20px}
.pbzh-eyebrow-dot{width:8px;height:8px;border-radius:50%;background:var(--ink);animation:dp 2.5s ease-in-out infinite}
@keyframes dp{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.4;transform:scale(0.8)}}
.pbzh-eyebrow-text{font-size:11px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--ink)}
.pbzh-hero h1{font-size:clamp(2.4rem,4.5vw,4rem);font-weight:800;letter-spacing:-0.03em;line-height:1.05;color:var(--dark);margin-bottom:24px}
.pbzh-hero h1 em{font-style:normal;color:var(--ink)}
.pbzh-hero-desc{font-size:1.1rem;font-weight:300;line-height:1.85;color:var(--muted);max-width:440px;margin-bottom:40px}
.pbzh-hero-desc strong{color:var(--dark);font-weight:600}
.pbzh-badges{display:flex;flex-wrap:wrap;gap:10px;margin-top:48px}
.pbzh-badge{display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:600;color:var(--muted);background:var(--card);border:1px solid var(--border);padding:8px 14px;border-radius:100px}
.pbzh-badge svg{color:var(--ink);flex-shrink:0}
.pbzh-hero-img{border-radius:var(--radius);overflow:hidden;aspect-ratio:4/3;background:linear-gradient(160deg,#C8E6C9 0%,#E8E4DC 60%,#D4E0D4 100%);position:relative}
.pbzh-placeholder{width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px}
.pbzh-placeholder span{font-size:11px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:rgba(0,128,32,0.25)}
.pbzh-hero-badge{position:absolute;bottom:20px;left:20px;right:20px;background:rgba(246,243,238,0.95);backdrop-filter:blur(16px);border:1px solid var(--border);border-radius:var(--radius-sm);padding:16px 20px;display:flex;align-items:center;gap:12px}
.pbzh-hero-badge-icon{width:36px;height:36px;border-radius:50%;background:var(--ink);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.pbzh-hero-badge-text strong{display:block;font-size:13px;font-weight:700;color:var(--dark);margin-bottom:2px}
.pbzh-hero-badge-text span{font-size:12px;color:var(--muted)}
.pbzh-marquee{overflow:hidden;background:var(--dark);padding:14px 0;margin-top:64px}
.pbzh-marquee-track{display:flex;gap:0;width:max-content;animation:mq 28s linear infinite}
@keyframes mq{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.pbzh-marquee-item{display:inline-flex;align-items:center;gap:28px;padding:0 28px;font-size:12px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.55);white-space:nowrap}
.pbzh-marquee-sep{width:4px;height:4px;border-radius:50%;background:var(--ink);flex-shrink:0}
.pbzh-main{flex:1;padding:80px 48px;max-width:1400px;margin:0 auto;width:100%}
.pbzh-section-tag{display:inline-flex;align-items:center;gap:8px;margin-bottom:16px}
.pbzh-section-tag-line{width:24px;height:2px;background:var(--ink);border-radius:2px}
.pbzh-section-tag-text{font-size:11px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--ink)}
.pbzh-section-title{font-size:clamp(1.8rem,3vw,2.8rem);font-weight:800;letter-spacing:-0.03em;line-height:1.1;color:var(--dark);margin-bottom:16px}
.pbzh-section-title em{font-style:normal;color:var(--ink)}
.pbzh-section-desc{font-size:1.05rem;font-weight:300;line-height:1.85;color:var(--muted);max-width:520px}
.pbzh-atelier{margin-bottom:80px}
.pbzh-atelier-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:48px}
.pbzh-atelier-card{background:var(--card);border-radius:var(--radius);padding:36px 28px;border:1px solid var(--border);transition:border-color 0.3s,transform 0.3s}
.pbzh-atelier-card:hover{border-color:var(--ink);transform:translateY(-4px)}
.pbzh-atelier-card-icon{width:48px;height:48px;border-radius:var(--radius-sm);background:rgba(0,128,32,0.08);display:flex;align-items:center;justify-content:center;margin-bottom:20px;color:var(--ink)}
.pbzh-atelier-card h3{font-size:1.1rem;font-weight:700;color:var(--dark);margin-bottom:10px}
.pbzh-atelier-card p{font-size:14px;font-weight:300;color:var(--muted);line-height:1.75}
.pbzh-devis{margin-bottom:80px}
.pbzh-devis-grid{display:grid;grid-template-columns:1.3fr 1fr;gap:48px;align-items:start;margin-top:48px}
.pbzh-chat{background:var(--white);border-radius:var(--radius);border:1px solid var(--border);box-shadow:var(--shadow);overflow:hidden;display:flex;flex-direction:column}
.pbzh-chat-hdr{padding:20px 24px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:14px;background:rgba(0,128,32,0.03)}
.pbzh-chat-avatar{width:40px;height:40px;border-radius:50%;background:var(--ink);display:flex;align-items:center;justify-content:center;color:#fff;flex-shrink:0}
.pbzh-chat-info strong{display:block;font-size:14px;font-weight:700;color:var(--dark)}
.pbzh-chat-info span{font-size:12px;color:var(--muted)}
.pbzh-chat-status{margin-left:auto;display:flex;align-items:center;gap:6px}
.pbzh-status-dot{width:8px;height:8px;border-radius:50%;background:#22C55E;animation:dp 2.5s ease-in-out infinite}
.pbzh-status-text{font-size:11px;font-weight:600;color:#22C55E}
.pbzh-chat-body{flex:1;padding:20px 24px;display:flex;flex-direction:column;gap:12px;min-height:380px;max-height:520px;overflow-y:auto}
.pbzh-chat-body::-webkit-scrollbar{width:4px}
.pbzh-chat-body::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px}
.pbzh-msg{max-width:88%;display:flex;flex-direction:column;gap:4px}
.pbzh-msg-bot{align-self:flex-start}
.pbzh-msg-user{align-self:flex-end}
.pbzh-msg-bubble{padding:10px 14px;border-radius:2px;font-size:14px;line-height:1.6;white-space:pre-wrap}
.pbzh-msg-bot .pbzh-msg-bubble{background:var(--card);color:var(--dark);border-left:3px solid var(--ink)}
.pbzh-msg-user .pbzh-msg-bubble{background:var(--ink);color:var(--white)}
.pbzh-msg-time{font-size:10px;color:var(--muted);padding:0 4px}
.pbzh-msg-user .pbzh-msg-time{text-align:right}
.pbzh-typing{display:none;align-self:flex-start;gap:4px;align-items:center;padding:10px 14px;background:var(--card);border-radius:2px;border-left:3px solid var(--ink)}
.pbzh-typing span{width:6px;height:6px;border-radius:50%;background:rgba(0,128,32,0.3);animation:td 1.2s ease-in-out infinite}
.pbzh-typing span:nth-child(2){animation-delay:0.2s}
.pbzh-typing span:nth-child(3){animation-delay:0.4s}
@keyframes td{0%,60%,100%{opacity:0.3;transform:translateY(0)}30%{opacity:1;transform:translateY(-4px)}}
.pbzh-step{background:var(--bg);border-radius:var(--radius-sm);padding:18px;border:1px solid var(--border);margin-bottom:4px}
.pbzh-step-title{font-size:13px;font-weight:700;color:var(--dark);margin-bottom:12px}
.pbzh-choices{display:flex;flex-wrap:wrap;gap:8px}
.pbzh-choice{padding:9px 16px;border-radius:100px;font-size:13px;font-weight:600;border:1.5px solid var(--border);background:var(--white);color:var(--dark);cursor:pointer;transition:all 0.2s;font-family:Outfit,sans-serif}
.pbzh-choice:hover{border-color:var(--ink);color:var(--ink);background:rgba(0,128,32,0.04)}
.pbzh-choice.selected{background:var(--ink);color:var(--white);border-color:var(--ink)}
.pbzh-input-area{padding:12px 16px;border-top:1px solid var(--border)}
.pbzh-input-row{display:flex;gap:8px;align-items:flex-end}
.pbzh-file-btn{width:42px;height:42px;border-radius:var(--radius-sm);border:1.5px solid var(--border);background:var(--bg);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:border-color 0.2s;flex-shrink:0;color:var(--muted)}
.pbzh-file-btn:hover{border-color:var(--ink);color:var(--ink)}
.pbzh-file-btn.has-file{border-color:var(--ink);color:var(--ink);background:rgba(0,128,32,0.06)}
#pbzh-file-input{display:none}
.pbzh-input{flex:1;min-width:0;padding:10px 14px;border-radius:var(--radius-sm);border:1.5px solid var(--border);background:var(--bg);font-family:Outfit,sans-serif;font-size:14px;color:var(--dark);outline:none;resize:none;line-height:1.5;max-height:120px;overflow:hidden}
.pbzh-input:focus{border-color:var(--ink)}
.pbzh-input::placeholder{color:rgba(0,128,32,0.35)}
.pbzh-send{width:42px;height:42px;border-radius:var(--radius-sm);background:var(--ink);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background 0.2s;flex-shrink:0;color:var(--white)}
.pbzh-send:hover{background:var(--ink-dark)}
.pbzh-send:disabled{background:var(--border);cursor:default}
.pbzh-file-preview{display:none;align-items:center;gap:8px;width:100%;padding:8px 12px;background:rgba(0,128,32,0.06);border-radius:var(--radius-sm);border:1px solid rgba(0,128,32,0.15);margin-top:8px}
.pbzh-file-preview.visible{display:flex}
.pbzh-file-preview-name{font-size:12px;color:var(--dark);flex:1}
.pbzh-file-preview-remove{background:none;border:none;cursor:pointer;color:var(--muted);padding:2px;font-size:16px}
.pbzh-file-preview-remove:hover{color:#EF4444}
.pbzh-cards{display:flex;flex-direction:column;gap:16px}
.pbzh-card{background:var(--card);border-radius:var(--radius);padding:24px;border:1px solid var(--border);display:flex;gap:16px;align-items:flex-start;transition:border-color 0.2s}
.pbzh-card:hover{border-color:rgba(0,128,32,0.3)}
.pbzh-card-icon{width:44px;height:44px;border-radius:var(--radius-sm);background:rgba(0,128,32,0.08);display:flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--ink)}
.pbzh-card h4{font-size:14px;font-weight:700;color:var(--dark);margin-bottom:4px}
.pbzh-card p{font-size:14px;color:var(--muted);line-height:1.6}
.pbzh-card a{color:var(--ink);text-decoration:none;font-weight:500}
.pbzh-card a:hover{text-decoration:underline}
.pbzh-tech{margin-bottom:80px}
.pbzh-tech-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:48px}
.pbzh-tech-card{border-radius:var(--radius);padding:36px 28px;border:1px solid var(--border);background:var(--card);transition:border-color 0.3s,transform 0.3s}
.pbzh-tech-card:hover{border-color:var(--ink);transform:translateY(-4px)}
.pbzh-tech-card h3{font-size:1.5rem;font-weight:800;letter-spacing:-0.02em;color:var(--dark);margin-bottom:12px}
.pbzh-tech-card p{font-size:14px;font-weight:300;color:var(--muted);line-height:1.75;margin-bottom:20px}
.pbzh-tech-tags{display:flex;flex-wrap:wrap;gap:6px}
.pbzh-tag{font-size:10px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--ink);background:rgba(0,128,32,0.07);padding:4px 10px;border-radius:100px}
.pbzh-footer{background:var(--dark);padding:48px}
.pbzh-footer-inner{max-width:1400px;margin:0 auto;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:24px}
.pbzh-footer-logo{font-family:Outfit,sans-serif;font-size:20px;font-weight:800;letter-spacing:-0.02em;color:var(--white)}
.pbzh-footer-logo span{opacity:0.4;font-weight:600;margin:0 4px}
.pbzh-footer-links{display:flex;gap:28px}
.pbzh-footer-links a{font-size:13px;color:rgba(255,255,255,0.45);text-decoration:none;transition:color 0.2s}
.pbzh-footer-links a:hover{color:var(--white)}
.pbzh-footer-bottom{max-width:1400px;margin:32px auto 0;padding-top:24px;border-top:1px solid rgba(255,255,255,0.08);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px}
.pbzh-footer-bottom span{font-size:12px;color:rgba(255,255,255,0.3)}
.pbzh-success{text-align:center;padding:48px 32px;display:none}
.pbzh-success-icon{width:64px;height:64px;border-radius:50%;background:rgba(0,128,32,0.1);display:flex;align-items:center;justify-content:center;margin:0 auto 20px;color:var(--ink)}
.pbzh-success h3{font-size:1.3rem;font-weight:700;color:var(--dark);margin-bottom:12px}
.pbzh-success p{font-size:14px;color:var(--muted);line-height:1.7}
@media(max-width:1024px){.pbzh-hero{grid-template-columns:1fr;padding:60px 32px 0}.pbzh-devis-grid{grid-template-columns:1fr}.pbzh-atelier-grid,.pbzh-tech-grid{grid-template-columns:1fr 1fr}}
@media(max-width:768px){.pbzh-header{padding:0 20px}.pbzh-header-tag{display:none}.pbzh-hero{padding:40px 20px 0;gap:32px}.pbzh-main{padding:48px 20px}.pbzh-atelier-grid,.pbzh-tech-grid{grid-template-columns:1fr}.pbzh-footer{padding:36px 20px}.pbzh-footer-inner{flex-direction:column;align-items:flex-start}}
</style>
<div class="pbzh">
