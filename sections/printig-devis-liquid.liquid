<script>
(function(){
var WEBHOOK = 'https://n8n.srv1486051.hstgr.cloud/webhook/devis-printbzh';
var body = document.getElementById('pbzh-body');
var input = document.getElementById('pbzh-input');
var sendBtn = document.getElementById('pbzh-send');
var fileInput = document.getElementById('pbzh-file-input');
var fileBtn = document.getElementById('pbzh-file-btn');
var preview = document.getElementById('pbzh-preview');
var filename = document.getElementById('pbzh-filename');
var rmBtn = document.getElementById('pbzh-rm');
var chat = document.getElementById('pbzh-chat');

var pendingFile = null;
var history = [];
var step = 0;
var selectedTech = '';

function addMsg(text, type){
  var d=document.createElement('div');
  d.className='pbzh-msg pbzh-msg-'+type;
  var b=document.createElement('div');
  b.className='pbzh-msg-bubble';
  b.textContent=text;
  d.appendChild(b);
  var t=document.createElement('div');
  t.className='pbzh-msg-time';
  t.textContent=new Date().toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'});
  d.appendChild(t);
  body.appendChild(d);
  body.scrollTop=body.scrollHeight;
}

function showTyping(){
  var d=document.createElement('div');
  d.className='pbzh-typing';
  d.id='pbzh-typing';
  d.innerHTML='<span></span><span></span><span></span>';
  body.appendChild(d);
  body.scrollTop=body.scrollHeight;
}
function hideTyping(){
  var t=document.getElementById('pbzh-typing');
  if(t)t.remove();
}

function showStep(title, choices){
  var s=document.createElement('div');
  s.className='pbzh-step';
  var t=document.createElement('div');
  t.className='pbzh-step-title';
  t.textContent=title;
  s.appendChild(t);
  var c=document.createElement('div');
  c.className='pbzh-choices';
  choices.forEach(function(ch){
    var b=document.createElement('button');
    b.className='pbzh-choice';
    b.textContent=ch;
    b.onclick=function(){ selectChoice(ch,s); };
    c.appendChild(b);
  });
  s.appendChild(c);
  body.appendChild(s);
  body.scrollTop=body.scrollHeight;
}

function selectChoice(choice, stepEl){
  var btns=stepEl.querySelectorAll('.pbzh-choice');
  btns.forEach(function(b){b.classList.remove('selected');});
  event.target.classList.add('selected');
  addMsg(choice,'user');
  setTimeout(function(){
    if(step===0){
      selectedTech=choice;
      step=1;
      showTyping();
      setTimeout(function(){
        hideTyping();
        showStep('Quel type de projet ?',['T-shirts & textiles','Casquettes & accessoires','Vêtements de travail','Autre']);
      },800);
    } else if(step===1){
      step=2;
      showTyping();
      setTimeout(function(){
        hideTyping();
        var p=document.createElement('div');
        p.className='pbzh-msg pbzh-msg-bot';
        var b=document.createElement('div');
        b.className='pbzh-msg-bubble';
        b.textContent='Parfait ! Pour finaliser ton devis, peux-tu me donner ton nom et email ? Ou tu peux directement envoyer ta demande.';
        p.appendChild(b);
        body.appendChild(p);
        body.scrollTop=body.scrollHeight;
        input.disabled=false;
        sendBtn.disabled=false;
        input.focus();
      },800);
    }
  },300);
}

function doSend(){
  var txt=input.value.trim();
  if(!txt && !pendingFile) return;
  var display=txt;
  if(pendingFile) display+=(txt?' ':'')+'📎 '+pendingFile.name;
  addMsg(display,'user');
  input.value='';
  sendBtn.disabled=true;
  showTyping();
  var formData={message:txt,technique:selectedTech,history:history};
  if(pendingFile){
    var reader=new FileReader();
    reader.onload=function(e){
      formData.file={name:pendingFile.name,type:pendingFile.type,data:e.target.result.split(',')[1]};
      sendToWebhook(formData);
    };
    reader.readAsDataURL(pendingFile);
  } else {
    sendToWebhook(formData);
  }
}

function sendToWebhook(data){
  fetch(WEBHOOK,{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify(data)
  }).then(function(r){return r.json();})
    .then(function(d){
      hideTyping();
      var reply=d.reply||d.message||"Merci ! On te r&eacute;pond sous 48h.";
      addMsg(reply,'bot');
      history.push({role:'user',content:data.message},{role:'assistant',content:reply});
      input.disabled=true;
      sendBtn.disabled=true;
      input.placeholder='Demande envoy&eacute;e !';
      // show success in chat
      var s=document.createElement('div');
      s.className='pbzh-success';
      s.innerHTML='<div class="pbzh-success-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg></div><h3>Demande envoy&eacute;e !</h3><p>On te r&eacute;pond sous 48h par email.</p>';
      body.appendChild(s);
      body.scrollTop=body.scrollHeight;
    })
    .catch(function(){
      hideTyping();
      addMsg('Erreur de connexion. Tu peux nous envoyer un email directement : contact@printig.bzh','bot');
    });
}

// File handling
fileInput.addEventListener('change',function(){
  if(fileInput.files[0]){
    pendingFile=fileInput.files[0];
    fileBtn.classList.add('has-file');
    preview.classList.add('visible');
    filename.textContent=pendingFile.name;
    sendBtn.disabled=false;
    input.placeholder='Ajoute un message ou envoie directement';
  }
});
rmBtn.addEventListener('click',function(){
  pendingFile=null;
  fileInput.value='';
  fileBtn.classList.remove('has-file');
  preview.classList.remove('visible');
  if(!input.value.trim()) sendBtn.disabled=true;
  input.placeholder='D&eacute;cris ton projet ou choisis une option…';
});

input.addEventListener('input',function(){
  if(!input.disabled) sendBtn.disabled=!input.value.trim() && !pendingFile;
  // auto-resize
  input.style.height='auto';
  input.style.height=Math.min(input.scrollHeight,120)+'px';
});
input.addEventListener('keydown',function(e){
  if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();doSend();}
});
sendBtn.addEventListener('click',doSend);

// Init
setTimeout(function(){
  showTyping();
  setTimeout(function(){
    hideTyping();
    showStep('Quelle technique t'int&eacute;resse ?',['S&eacute;rigraphie','Broderie','Marquage DTF','Je ne sais pas encore']);
  },1000);
},500);
})();
</script>

