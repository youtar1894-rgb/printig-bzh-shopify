/* ════════════════════════════════════
   CONTACT
════════════════════════════════════ */
#pbzh-contact {
  position:relative;
  background:var(--bg-2);
  padding:120px 6vw;
  overflow:hidden;
}
.pbzh-contact-grid {
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:80px; max-width:1400px; margin:0 auto;
  position:relative; z-index:10;
}
.pbzh-contact-h2 {
  font-family:var(--display);
  font-weight:900;
  font-size:clamp(1.8rem,3vw,3rem);
  line-height:1; letter-spacing:-.03em;
  color:var(--light); margin-bottom:24px;
}
.pbzh-contact-h2 em { font-style:normal; color:var(--orange); }
.pbzh-contact-desc {
  font-family:var(--body);
  font-size:1.05rem; font-weight:300; line-height:1.9;
  color:var(--muted); max-width:380px; margin-bottom:52px;
}
.pbzh-contact-items { display:flex; flex-direction:column; gap:0; }
.pbzh-contact-item {
  display:flex; gap:16px; align-items:flex-start;
  padding:20px 0;
  border-bottom:1px solid var(--border);
}
.pbzh-contact-item:first-child { border-top:1px solid var(--border); }
.pbzh-contact-icon {
  width:36px; height:36px; border-radius:2px;
  background:var(--green-dim);
  border:1px solid var(--border);
  display:flex; align-items:center; justify-content:center;
  flex-shrink:0;
}
.pbzh-contact-label {
  display:block; font-family:var(--body);
  color:var(--light); font-size:.85rem; font-weight:500; margin-bottom:2px;
}
.pbzh-contact-val {
  font-family:var(--body); color:var(--muted); font-size:.8rem; line-height:1.5;
}

/* Chatbot */
.pbzh-chatbot {
  background:var(--bg);
  border:1px solid var(--border);
  border-radius:2px; overflow:hidden;
  display:flex; flex-direction:column;
  height:520px; position:relative;
}
.pbzh-chatbot::before {
  content:'';
  position:absolute; top:0; left:0; right:0; height:2px;
  background:var(--green);
}
.pbzh-chatbot-header {
  padding:18px 20px;
  display:flex; align-items:center; gap:12px;
  border-bottom:1px solid var(--border);
  background:rgba(2,5,211,0.05);
}
.pbzh-chatbot-avatar {
  width:34px; height:34px; border-radius:2px;
  background:var(--green);
  display:flex; align-items:center; justify-content:center;
  flex-shrink:0;
}
.pbzh-chatbot-title { font-family:var(--body); color:var(--light); font-weight:600; font-size:.9rem; }
.pbzh-chatbot-subtitle { font-family:var(--body); color:var(--muted); font-size:.72rem; }
.pbzh-chatbot-status { margin-left:auto; display:flex; align-items:center; gap:6px; }
.pbzh-chatbot-dot { width:7px; height:7px; border-radius:50%; background:#4ADE80; animation:pbzh-dot-pulse 2s ease-in-out infinite; }
.pbzh-chatbot-status span { font-family:var(--body); color:#4ADE80; font-size:.72rem; }
.pbzh-chatbot-messages {
  flex:1; overflow-y:auto; padding:16px;
  display:flex; flex-direction:column; gap:10px;
  scroll-behavior:smooth;
}
.pbzh-chatbot-messages::-webkit-scrollbar { width:3px; }
.pbzh-chatbot-messages::-webkit-scrollbar-track { background:transparent; }
.pbzh-chatbot-messages::-webkit-scrollbar-thumb { background:var(--border); border-radius:2px; }
.pbzh-msg { max-width:85%; }
.pbzh-msg-bot  { align-self:flex-start; }
.pbzh-msg-user { align-self:flex-end; }
.pbzh-msg-bubble {
  padding:10px 14px; border-radius:2px;
  font-family:var(--body); font-size:.82rem; line-height:1.6;
  white-space:pre-wrap;
}
.pbzh-msg-bot  .pbzh-msg-bubble { background:var(--green-dim); color:var(--light); border-left:2px solid var(--green); }
.pbzh-msg-user .pbzh-msg-bubble { background:var(--orange-dim); color:var(--light); border-right:2px solid var(--orange); }
.pbzh-typing {
  align-self:flex-start; padding:10px 14px;
  background:var(--green-dim); border-radius:2px;
  border-left:2px solid var(--green);
  display:flex; gap:4px; align-items:center;
}
.pbzh-typing span {
  width:5px; height:5px; border-radius:50%;
  background:rgba(2,5,211,0.3);
  animation:pbzh-typingDot 1.2s ease-in-out infinite;
}
.pbzh-typing span:nth-child(2) { animation-delay:.2s; }
.pbzh-typing span:nth-child(3) { animation-delay:.4s; }
@keyframes pbzh-typingDot {
  0%,60%,100% { opacity:.3; transform:translateY(0); }
  30% { opacity:1; transform:translateY(-4px); }
}
.pbzh-chatbot-input {
  padding:12px 14px;
  border-top:1px solid var(--border);
  display:flex; gap:8px;
}
.pbzh-chatbot-input input {
  flex:1; background:rgba(2,5,211,0.03);
  border:1px solid var(--border); border-radius:2px;
  padding:10px 14px; color:var(--light);
  font-family:var(--body); font-size:.82rem;
  outline:none; transition:border-color .3s ease;
}
.pbzh-chatbot-input input:focus { border-color:var(--green); }
.pbzh-chatbot-input input::placeholder { color:rgba(2,5,211,0.3); }
.pbzh-chatbot-send {
  width:40px; height:40px; border-radius:8px;
  background:var(--orange); border:none; cursor:pointer;
  display:flex; align-items:center; justify-content:center;
  transition:background .3s ease;
  flex-shrink:0;
}
.pbzh-chatbot-send:disabled { background:rgba(2,5,211,0.1); cursor:default; }
.pbzh-chatbot-send:not(:disabled):hover { background:var(--orange-hover); }

/* ════════════════════════════════════
   FOOTER
════════════════════════════════════ */
#pbzh-footer {
  background:var(--bg);
  padding:60px 6vw 36px;
  border-top:1px solid var(--border);
}
.pbzh-footer-grid {
  display:grid;
  grid-template-columns:2fr 1fr 1fr;
  gap:60px; max-width:1400px; margin:0 auto 48px;
}
.pbzh-footer-brand p {
  font-family:var(--body); font-size:.85rem; line-height:1.7;
  color:var(--muted); max-width:280px; margin-top:16px;
}
.pbzh-footer-col h4 {
  font-family:var(--body); font-size:.65rem; font-weight:600;
  letter-spacing:.2em; text-transform:uppercase;
  color:var(--green-bright); margin-bottom:20px;
}
.pbzh-footer-col ul { list-style:none; display:flex; flex-direction:column; gap:10px; }
.pbzh-footer-col ul a {
  font-family:var(--body); color:var(--muted); font-size:.85rem;
  transition:color .3s ease;
}
.pbzh-footer-col ul a:hover { color:var(--light); }
.pbzh-footer-bottom {
  max-width:1400px; margin:0 auto;
  padding-top:24px; border-top:1px solid var(--border);
  display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:12px;
}
.pbzh-footer-bottom span { font-family:var(--body); font-size:.75rem; color:rgba(255,255,255,0.5); }

/* ════════════════════════════════════
   CHAT WIDGET
════════════════════════════════════ */
#pbzh-chat-widget { position:fixed; bottom:28px; right:28px; z-index:9999; }
.pbzh-chat-panel {
  position:absolute; bottom:70px; right:0; width:360px;
  opacity:0; pointer-events:none;
  transform:translateY(16px) scale(.95);
  transform-origin:bottom right;
  transition:all .3s cubic-bezier(.22,1,.36,1);
}
.pbzh-chat-widget-open .pbzh-chat-panel {
  opacity:1; pointer-events:all;
  transform:translateY(0) scale(1);
}
.pbzh-chat-toggle {
  width:54px; height:54px; border-radius:50%;
  background:var(--green); border:none; cursor:pointer;
  display:flex; align-items:center; justify-content:center;
  box-shadow: 0 4px 20px rgba(2,5,211,0.3);
  transition:transform .3s ease, box-shadow .3s ease;
  position:relative;
}
.pbzh-chat-toggle:hover { transform:scale(1.06); box-shadow:0 6px 28px rgba(255,255,255,0.5); }
.pbzh-chat-toggle .icon-open  { position:absolute; transition:opacity .2s ease; }
.pbzh-chat-toggle .icon-close { position:absolute; opacity:0; transition:opacity .2s ease; }
.pbzh-chat-widget-open .pbzh-chat-toggle .icon-open  { opacity:0; }
.pbzh-chat-widget-open .pbzh-chat-toggle .icon-close { opacity:1; }
.pbzh-chat-unread {
  position:absolute; top:-6px; right:-6px;
  width:20px; height:20px; border-radius:50%;
  background:var(--orange);
  font-family:var(--body); font-size:.65rem; font-weight:700;
  color:#fff; display:flex; align-items:center; justify-content:center;
}

/* ════════════════════════════════════
   RESPONSIVE
════════════════════════════════════ */
@media (max-width:1024px) {
  .pbzh-atelier-inner  { grid-template-columns:1fr; }
  .pbzh-contact-grid   { grid-template-columns:1fr; gap:60px; }
  .pbzh-temoignages-grid { grid-template-columns:1fr 1fr; }
  .pbzh-produits-grid  { grid-template-columns:repeat(2,1fr); }
  .pbzh-footer-grid    { grid-template-columns:1fr 1fr; }
  .pbzh-atelier-badge  { left:0; }
}
@media (max-width:768px) {
  #pbzh-header { padding:14px 24px; }
  .pbzh-nav { display:none; }
  .pbzh-nav-toggle { display:flex; }
  .pbzh-nav.is-open {
    display:flex; flex-direction:column;
    position:fixed; top:0; left:0; right:0; bottom:0;
    background:rgba(245,240,234,.98);
    align-items:center; justify-content:center;
    gap:28px; z-index:999;
  }
  .pbzh-nav.is-open a { font-size:1.1rem; }
  .pbzh-temoignages-grid { grid-template-columns:1fr; }
  .pbzh-produits-grid    { grid-template-columns:1fr 1fr; }
  .pbzh-footer-grid      { grid-template-columns:1fr; gap:32px; }
  .pbzh-stanley { display:none; }
  .pbzh-chat-panel { width:calc(100vw - 56px); right:-8px; }
  .pbzh-tech-h3 { font-size:clamp(2rem, 8vw, 3.5rem); }
  #pbzh-atelier, #pbzh-produits, #pbzh-temoignages, #pbzh-contact { padding:80px 6vw; }
}
@media (max-width:480px) {
  .pbzh-produits-grid { grid-template-columns:1fr; }
  .pbzh-hero-ctas { flex-direction:column; }
  .pbzh-btn-primary, .pbzh-btn-outline { width:100%; justify-content:center; }
}

