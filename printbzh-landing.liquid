{% comment %}
  PRINT.BZH — Landing Page Neo-Futurisme / Maximalisme
  Fichier  : sections/printbzh-landing.liquid
  Style    : Craft · Atelier · Bleu Reflex + Or + Blanc Cassé
  Fonts    : PriceCheck (H1/H2) — uploader pricecheck.woff2 + pricecheck.woff dans Shopify Assets
             Outfit (corps) — Google Fonts
  Images   : Aucune obligatoire (blocs couleur)
             Optionnel : printbzh-hero-bg.jpg, printbzh-atelier.jpg
  n8n      : Remplacer N8N_WEBHOOK par l'URL réelle
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap">

<style>
/* ─── Workfolk custom font ─── */
@font-face {
  font-family: 'PriceCheck';
  src: url('{{ "pricecheck.woff2" | asset_url }}') format('woff2'),
       url('{{ "pricecheck.woff"  | asset_url }}') format('woff');
  font-weight: 400 900;
  font-style: normal;
  font-display: swap;
}

/* ─── Variables ─── */
:root {
  --bg:           #F5F0EA;   /* beige crème */
  --bg-2:         #2A2A2A;   /* sections sombres */
  --green:        #0205D3;   /* bleu roi électrique */
  --green-bright: #0D15E8;
  --green-glow:   rgba(2,5,211,0.15);
  --green-dim:    rgba(2,5,211,0.07);
  --orange:       #0205D3;   /* bleu roi (CTAs = bleu) */
  --orange-hover: #091747;   /* navy hover */
  --orange-glow:  rgba(2,5,211,0.2);
  --orange-dim:   rgba(2,5,211,0.07);
  --light:        #091747;   /* bleu marine profond */
  --muted:        rgba(9,23,71,0.55);
  --border:       rgba(9,23,71,0.12);
  --display:      'PriceCheck', 'Impact', sans-serif;
  --body:         'Outfit', sans-serif;
}

/* ─── Reset ─── */
.pbzh * { margin:0; padding:0; box-sizing:border-box; }
.pbzh a { text-decoration:none; color:inherit; }
.pbzh img { display:block; width:100%; height:100%; object-fit:cover; }

/* ─── Animations ─── */
@keyframes pbzh-up {
  from { opacity:0; transform:translateY(80px); }
  to   { opacity:1; transform:translateY(0); }
}
@keyframes pbzh-fade {
  from { opacity:0; } to { opacity:1; }
}
@keyframes pbzh-header-in {
  from { opacity:0; transform:translateY(-100%); }
  to   { opacity:1; transform:translateY(0); }
}
@keyframes pbzh-marquee {
  from { transform:translateX(0); }
  to   { transform:translateX(-50%); }
}
@keyframes pbzh-glow-pulse {
  0%,100% { opacity:.6; }
  50%     { opacity:1; }
}
@keyframes pbzh-scan {
  from { transform:translateY(-100%); }
  to   { transform:translateY(100vh); }
}
@keyframes pbzh-glitch {
  0%   { clip-path:inset(0 0 100% 0); transform:translateX(0); }
  10%  { clip-path:inset(10% 0 80% 0); transform:translateX(-4px); }
  20%  { clip-path:inset(30% 0 50% 0); transform:translateX(4px); }
  30%  { clip-path:inset(50% 0 30% 0); transform:translateX(-2px); }
  40%  { clip-path:inset(70% 0 10% 0); transform:translateX(3px); }
  50%  { clip-path:inset(80% 0 5% 0);  transform:translateX(-4px); }
  60%  { clip-path:inset(60% 0 20% 0); transform:translateX(2px); }
  70%  { clip-path:inset(40% 0 40% 0); transform:translateX(-3px); }
  80%  { clip-path:inset(20% 0 60% 0); transform:translateX(4px); }
  90%  { clip-path:inset(5% 0 90% 0);  transform:translateX(-2px); }
  100% { clip-path:inset(0 0 100% 0);  transform:translateX(0); }
}
@keyframes pbzh-float {
  0%,100% { transform:translateY(0); }
  50%     { transform:translateY(-12px); }
}
@keyframes pbzh-dot-pulse {
  0%,100% { transform:scale(1); opacity:.4; }
  50%     { transform:scale(1.8); opacity:1; }
}

/* ─── Reveal ─── */
.pbzh-reveal {
  opacity:0;
  transform:translateY(60px);
  transition: opacity .8s cubic-bezier(.22,1,.36,1),
              transform .8s cubic-bezier(.22,1,.36,1);
}
.pbzh-reveal.is-visible { opacity:1; transform:translateY(0); }

/* ─── Dot grid background ─── */
.pbzh-dots { display:none; }

/* ─── Scanline ─── */
.pbzh-scanline {
  display:none;
}

/* ─── Grain supprimé ─── */
.pbzh::after { display:none; }

/* ─── Brackets & section numbers supprimés ─── */
.pbzh-bracket,
.pbzh-section-num { display:none; }

/* ════════════════════════════════════
   HEADER
════════════════════════════════════ */
#pbzh-header {
  position:fixed; top:0; left:0; right:0; z-index:1000;
  padding:18px 40px;
  display:flex; align-items:center; justify-content:space-between;
  transition: background .4s ease, border-color .4s ease;
  border-bottom:1px solid transparent;
  animation: pbzh-header-in .6s ease-out forwards;
}
#pbzh-header.is-scrolled {
  background: rgba(245,240,234,0.95);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom-color: var(--border);
}
.pbzh-logo {
  font-family: var(--display);
  font-weight:900;
  font-size:1.8rem;
  color:var(--green);
  letter-spacing:-.02em;
  display:flex; align-items:center;
}
.pbzh-logo .dot {
  color:var(--orange);
  font-size:2.4rem;
  line-height:1;
}
.pbzh-nav {
  display:flex; gap:32px; align-items:center; list-style:none;
}
.pbzh-nav a {
  font-family:var(--body);
  font-size:.8rem; font-weight:500;
  letter-spacing:.1em; text-transform:uppercase;
  color:var(--muted);
  transition:color .3s ease;
  position:relative;
}
.pbzh-nav a::after {
  content:'';
  position:absolute; bottom:-4px; left:0; right:0;
  height:1px; background:var(--green);
  transform:scaleX(0); transform-origin:left;
  transition:transform .3s ease;
}
.pbzh-nav a:hover { color:var(--light); }
.pbzh-nav a:hover::after { transform:scaleX(1); }
.pbzh-nav-cta {
  font-family:var(--body);
  font-size:.75rem; font-weight:600;
  letter-spacing:.12em; text-transform:uppercase;
  color:#fff !important;
  background:var(--orange);
  padding:10px 22px; border-radius:8px;
  transition:background .3s ease !important;
}
.pbzh-nav-cta::after { display:none !important; }
.pbzh-nav-cta:hover {
  background:var(--orange-hover) !important;
  color:#fff !important;
}
.pbzh-nav-toggle {
  display:none; flex-direction:column; gap:5px;
  background:none; border:none; cursor:pointer; padding:4px;
}
.pbzh-nav-toggle span {
  display:block; width:24px; height:2px;
  background:var(--light); transition:all .3s ease;
}

/* Header fond initial */
#pbzh-header { background: var(--bg); }

/* ════════════════════════════════════
   HERO
════════════════════════════════════ */
#pbzh-hero {
  position:relative;
  width:100%; min-height:100vh;
  background:var(--bg);
  display:flex; flex-direction:column;
  justify-content:center;
  overflow:hidden;
  padding-top:80px;
}

/* Fond optionnel photo */
.pbzh-hero-photo {
  position:absolute; inset:0;
  /* background-image:url('{{ "printbzh-hero-bg.jpg" | asset_url }}');
     background-size:cover; background-position:center; */
  background:linear-gradient(145deg, #E8E3DA 0%, #F5F0EA 55%, #ECE8E0 100%);
}
.pbzh-hero-photo-overlay {
  position:absolute; inset:0;
  background:linear-gradient(to right, rgba(245,240,234,.92) 0%, rgba(245,240,234,.6) 60%, rgba(245,240,234,.15) 100%);
}

/* Accent bar gauche hero */
.pbzh-hero-lines {
  position:absolute; inset:0; pointer-events:none; z-index:2;
}
.pbzh-hero-lines::before {
  content:'';
  position:absolute; left:0; top:0; bottom:0;
  width:4px; background:var(--green);
}
.pbzh-hero-lines::after { display:none; }

/* Grille de points */
.pbzh-hero .pbzh-dots { opacity:.4; }

/* Scanline */
.pbzh-hero .pbzh-scanline { z-index:6; }

/* Contenu hero */
.pbzh-hero-content {
  position:relative; z-index:10;
  padding:0 6vw;
  width:100%;
}

/* Surtitre */
.pbzh-hero-eyebrow {
  display:inline-flex; align-items:center; gap:12px;
  margin-bottom:20px;
}
.pbzh-hero-eyebrow-tag {
  font-family:var(--body);
  font-size:.7rem; font-weight:600;
  letter-spacing:.25em; text-transform:uppercase;
  color:var(--green-bright);
  border:1px solid var(--border);
  padding:5px 14px; border-radius:20px;
  background:var(--green-dim);
}
.pbzh-hero-eyebrow-line { display:none; }

/* H1 massif */
.pbzh-hero-h1 {
  font-family:var(--display);
  font-weight:900;
  font-size:clamp(2.2rem, 4.5vw, 4.5rem);
  line-height:.95;
  letter-spacing:-.03em;
  color:var(--light);
  margin-bottom:0;
  overflow:visible;
}
.pbzh-hero-h1 .line-1 { display:block; }
.pbzh-hero-h1 .line-2 {
  display:block;
  color:var(--green);
}
.pbzh-hero-h1 .line-3 {
  display:block;
}

/* Divider supprimé */
.pbzh-hero-divider { display:none; }

/* Sous-titre + CTA */
.pbzh-hero-bottom {
  display:flex;
  align-items:flex-end;
  justify-content:space-between;
  flex-wrap:wrap;
  gap:40px;
}
.pbzh-hero-sub {
  font-family:var(--body);
  font-size:clamp(1rem, 1.3vw, 1.2rem);
  font-weight:300;
  line-height:1.8;
  color:var(--muted);
  max-width:440px;
}
.pbzh-hero-sub strong { color:var(--light); font-weight:500; }
.pbzh-hero-sep { color:var(--orange); margin:0 6px; }
.pbzh-hero-ctas { display:flex; gap:14px; flex-wrap:wrap; }

/* Boutons */
.pbzh-btn-primary {
  display:inline-flex; align-items:center; gap:10px;
  background:var(--orange); color:#fff;
  padding:16px 36px; border-radius:8px;
  font-family:var(--body); font-size:.85rem; font-weight:700;
  letter-spacing:.12em; text-transform:uppercase;
  border:none; cursor:pointer;
  transition:all .3s cubic-bezier(.22,1,.36,1);
}
.pbzh-btn-primary:hover {
  background:var(--orange-hover);
  transform:translateY(-2px);
  color:#fff;
}
.pbzh-btn-outline {
  display:inline-flex; align-items:center; gap:10px;
  background:transparent; color:var(--light);
  padding:15px 36px; border-radius:8px;
  font-family:var(--body); font-size:.85rem; font-weight:500;
  letter-spacing:.12em; text-transform:uppercase;
  border:1.5px solid var(--border);
  transition:all .3s ease;
}
.pbzh-btn-outline:hover {
  border-color:var(--green);
  color:var(--green);
  transform:translateY(-2px);
}

/* Badge Stanley Stella */
.pbzh-stanley {
  position:absolute; right:6vw; bottom:60px; z-index:10;
  text-align:right;
  border:1px solid var(--border);
  padding:16px 24px; border-radius:2px;
  background:rgba(250,247,242,0.92);
  backdrop-filter:blur(10px);
}
.pbzh-stanley-tag {
  font-family:var(--body); font-size:.65rem; font-weight:600;
  letter-spacing:.2em; text-transform:uppercase;
  color:var(--green-bright); display:block; margin-bottom:4px;
}
.pbzh-stanley-name {
  font-family:var(--display); font-weight:900; font-size:1.4rem;
  color:var(--light); letter-spacing:-.01em;
}

/* Scroll indicator */
.pbzh-scroll {
  position:absolute; bottom:32px; left:6vw; z-index:10;
  display:flex; align-items:center; gap:16px;
}
.pbzh-scroll-text {
  font-family:var(--body); font-size:.65rem; font-weight:500;
  letter-spacing:.25em; text-transform:uppercase; color:var(--muted);
}
.pbzh-scroll-bar {
  width:40px; height:1px;
  background:linear-gradient(to right, var(--green), transparent);
}

/* ════════════════════════════════════
   MARQUEE
════════════════════════════════════ */
.pbzh-marquee {
  overflow:hidden;
  background:var(--green);
  padding:14px 0;
  border-top:none;
  border-bottom:none;
}
.pbzh-marquee-track {
  display:flex; gap:0;
  width:max-content;
  animation:pbzh-marquee 22s linear infinite;
}
.pbzh-marquee-item {
  display:inline-flex; align-items:center; gap:32px;
  padding:0 32px;
  font-family:var(--display); font-weight:900;
  font-size:clamp(.9rem, 1.3vw, 1.1rem);
  letter-spacing:.12em; text-transform:uppercase;
  color:#fff; white-space:nowrap;
}
.pbzh-marquee-dot {
  width:6px; height:6px; border-radius:50%;
  background:var(--orange); flex-shrink:0;
}
.pbzh-marquee--dark {
  background:var(--bg-2);
}
.pbzh-marquee--dark .pbzh-marquee-item { color:var(--muted); }
.pbzh-marquee--dark .pbzh-marquee-dot  { background:var(--green); }
.pbzh-marquee--reverse .pbzh-marquee-track {
  animation-direction:reverse;
}

/* ════════════════════════════════════
   ATELIER
════════════════════════════════════ */
#pbzh-atelier {
  position:relative;
  background:var(--bg);
  padding:120px 6vw;
  overflow:hidden;
}
.pbzh-atelier-num {
  position:absolute; right:-2vw; top:40px;
  line-height:1;
}
.pbzh-atelier-inner {
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:80px; align-items:center;
  max-width:1400px; margin:0 auto;
  position:relative; z-index:2;
}
.pbzh-atelier-left { }
.pbzh-atelier-tag {
  display:inline-flex; align-items:center; gap:10px;
  margin-bottom:28px;
}
.pbzh-atelier-tag-text {
  font-family:var(--body); font-size:.75rem; font-weight:700;
  letter-spacing:.18em; text-transform:uppercase;
  color:var(--green);
}
.pbzh-atelier-tag-line { display:none; }
.pbzh-atelier-h2 {
  font-family:var(--display);
  font-weight:900;
  font-size:clamp(1.8rem, 3vw, 3rem);
  line-height:1;
  letter-spacing:-.03em;
  color:var(--light);
  margin-bottom:36px;
}
.pbzh-atelier-h2 em {
  font-style:normal;
  color:var(--green);
}
.pbzh-atelier-body {
  font-family:var(--body);
  font-size:1.05rem; font-weight:300; line-height:1.9;
  color:var(--muted); max-width:460px;
  margin-bottom:16px;
}
.pbzh-atelier-feats {
  display:flex; flex-direction:column; gap:12px;
  margin-top:36px;
}
.pbzh-atelier-feat {
  padding:20px 22px;
  background:var(--bg);
  border:1px solid var(--border);
  border-left:3px solid var(--green);
  border-radius:2px;
}
.pbzh-atelier-feat-icon {
  display:inline-flex; align-items:center; justify-content:center;
  width:30px; height:30px;
  background:var(--green-dim);
  border-radius:50%;
  margin-bottom:10px;
  color:var(--green);
  flex-shrink:0;
}
.pbzh-atelier-feat-title {
  font-family:var(--body);
  font-size:.875rem; font-weight:400;
  color:var(--light); line-height:1.6;
  margin-bottom:6px;
}
.pbzh-atelier-feat-title span {
  font-weight:700; color:var(--green);
}
.pbzh-atelier-feat-desc {
  font-family:var(--body);
  font-size:.82rem; font-weight:400;
  color:var(--muted); line-height:1.75;
}
.pbzh-atelier-right { position:relative; }
.pbzh-atelier-img-wrap {
  width:100%; aspect-ratio:4/5;
  border:1px solid var(--border);
  border-radius:2px; overflow:hidden;
  position:relative;
  background:linear-gradient(160deg,#C8CCF4,#E8E4DC);
}
.pbzh-atelier-img-wrap img { width:100%; height:100%; object-fit:cover; }
.pbzh-atelier-placeholder {
  position:absolute; inset:0;
  display:flex; flex-direction:column;
  align-items:center; justify-content:center; gap:16px;
}
.pbzh-atelier-placeholder span {
  font-family:var(--body); font-size:.7rem; font-weight:500;
  letter-spacing:.15em; text-transform:uppercase;
  color:rgba(2,5,211,0.20);
}
.pbzh-atelier-glow-border {
  display:none;
}
.pbzh-atelier-badge {
  position:absolute; bottom:24px; left:-24px; right:24px;
  background:rgba(245,240,234,0.95);
  border:1px solid var(--border); border-radius:2px;
  padding:18px 24px;
  backdrop-filter:blur(10px);
}
.pbzh-atelier-badge::before {
  content:'';
  position:absolute; top:0; left:0; right:0; height:2px;
  background:var(--orange);
}
.pbzh-atelier-badge strong {
  display:block; font-family:var(--body);
  color:var(--light); font-size:.85rem; font-weight:600;
  margin-bottom:2px;
}
.pbzh-atelier-badge span {
  font-family:var(--body);
  color:var(--muted); font-size:.75rem;
}

/* ════════════════════════════════════
   TECHNIQUES — Blocs couleur massifs
════════════════════════════════════ */
#pbzh-techniques { }
.pbzh-tech-header {
  background:var(--bg-2);
  padding:100px 6vw 80px;
  position:relative; overflow:hidden;
}
.pbzh-tech-header .pbzh-dots { opacity:.3; }
.pbzh-tech-header-inner {
  max-width:1400px; margin:0 auto;
  position:relative; z-index:2;
  display:flex; justify-content:space-between; align-items:flex-end;
  flex-wrap:wrap; gap:40px;
}
.pbzh-tech-header h2 {
  font-family:var(--display);
  font-weight:900;
  font-size:clamp(1.8rem,3.2vw,3.2rem);
  line-height:1; letter-spacing:-.03em;
  color:var(--light);
}
.pbzh-tech-header h2 em {
  font-style:normal;
  color:var(--green);
}
.pbzh-tech-header-sub {
  font-family:var(--body);
  font-size:1.05rem; font-weight:300; line-height:1.85;
  color:var(--muted); max-width:360px;
}

/* Bloc technique individuel */
.pbzh-tech-block {
  position:relative; min-height:90vh;
  display:flex; align-items:center;
  overflow:hidden;
}
.pbzh-tech-block:nth-child(odd)  .pbzh-tech-content { padding-left:6vw; }
.pbzh-tech-block:nth-child(even) .pbzh-tech-content { padding-left:auto; margin-left:auto; padding-right:6vw; text-align:right; }
.pbzh-tech-block:nth-child(even) .pbzh-tech-tag-list { justify-content:flex-end; }

/* Fonds couleur */
.pbzh-tech-block--seri {
  background:radial-gradient(ellipse at 30% 60%, rgba(2,5,211,0.05) 0%, var(--bg) 65%);
  border-top:1px solid var(--border);
}
.pbzh-tech-block--brode {
  background:radial-gradient(ellipse at 70% 40%, rgba(2,5,211,0.04) 0%, var(--bg-2) 65%);
}
.pbzh-tech-block--dtf {
  background:radial-gradient(ellipse at 20% 70%, rgba(2,5,211,0.05) 0%, var(--bg) 65%);
  border-bottom:1px solid var(--border);
}

/* Numéros décoratifs supprimés */
.pbzh-tech-bg-num { display:none; }

/* Ligne déco */
.pbzh-tech-vline {
  position:absolute; top:0; bottom:0; width:1px;
  background:linear-gradient(to bottom, transparent, rgba(2,5,211,0.3), transparent);
}
.pbzh-tech-block:nth-child(odd)  .pbzh-tech-vline { left:0; }
.pbzh-tech-block:nth-child(even) .pbzh-tech-vline { right:0; }

/* Contenu */
.pbzh-tech-content {
  position:relative; z-index:10;
  width:100%; max-width:700px;
  padding:100px 6vw;
}
.pbzh-tech-eyebrow {
  display:inline-flex; align-items:center; gap:10px;
  margin-bottom:24px;
}
.pbzh-tech-eyebrow-num {
  font-family:var(--body); font-size:.7rem; font-weight:700;
  letter-spacing:.2em; text-transform:uppercase;
  color:var(--orange);
}
.pbzh-tech-eyebrow-sep { display:none; }
.pbzh-tech-eyebrow-label {
  font-family:var(--body); font-size:.7rem; font-weight:500;
  letter-spacing:.2em; text-transform:uppercase; color:var(--muted);
}
.pbzh-tech-h3 {
  font-family:var(--display);
  font-weight:900;
  font-size:clamp(2rem, 4.5vw, 4.5rem);
  line-height:1; letter-spacing:-.04em;
  color:var(--light);
  margin-bottom:32px;
}
.pbzh-tech-h3 .glow {
  color:var(--green-bright);
}
.pbzh-tech-h3 .stroke {
  color:var(--green);
}
.pbzh-tech-desc {
  font-family:var(--body);
  font-size:1.05rem; font-weight:300; line-height:1.9;
  color:var(--muted); max-width:480px;
  margin-bottom:36px;
}
.pbzh-tech-tag-list { display:flex; flex-wrap:wrap; gap:8px; margin-bottom:36px; }
.pbzh-tech-tag {
  font-family:var(--body); font-size:.7rem; font-weight:500;
  letter-spacing:.1em; text-transform:uppercase;
  color:var(--muted);
  border:1px solid var(--border);
  padding:6px 14px; border-radius:20px;
  transition:border-color .3s ease, color .3s ease;
}
.pbzh-tech-tag:hover {
  border-color:var(--green);
  color:var(--green-bright);
}
.pbzh-tech-cta {
  display:inline-flex; align-items:center; gap:10px;
  font-family:var(--body); font-size:.8rem; font-weight:600;
