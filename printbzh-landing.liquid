<script>
(function(){
  const N8N_WEBHOOK      = 'https://n8n.srv1486051.hstgr.cloud/webhook/devis-printbzh';
const N8N_CHAT_WEBHOOK = 'https://n8n.srv1486051.hstgr.cloud/webhook/chat-v2';

  /* ── Header scroll ── */
  const header = document.getElementById('pbzh-header');
  window.addEventListener('scroll',()=>{
    header.classList.toggle('is-scrolled', window.scrollY > 50);
  },{ passive:true });

  /* ── Menu mobile ── */
  const toggle = document.getElementById('pbzh-nav-toggle');
  const nav    = document.getElementById('pbzh-nav');
  toggle?.addEventListener('click',()=> nav.classList.toggle('is-open'));
  nav?.querySelectorAll('a').forEach(a=> a.addEventListener('click',()=> nav.classList.remove('is-open')));

  /* ── Hero init ── */
  setTimeout(()=>{
    document.querySelectorAll('#pbzh-hero .pbzh-reveal').forEach(el=> el.classList.add('is-visible'));
  }, 120);

  /* ── IntersectionObserver ── */
  const obs = new IntersectionObserver((entries)=>{
    entries.forEach(e=>{
      if(!e.isIntersecting) return;
      const el = e.target;
      const d  = parseFloat(el.style.transitionDelay)||0;
      setTimeout(()=> el.classList.add('is-visible'), d*1000);
      obs.unobserve(el);
    });
  },{ threshold:0.12 });

  document.querySelectorAll('.pbzh-reveal').forEach(el=>{
    if(!el.closest('#pbzh-hero')) obs.observe(el);
  });

  /* ── Smooth scroll ── */
  document.querySelectorAll('a[href^="#pbzh-"]').forEach(a=>{
    a.addEventListener('click',e=>{
      const t = document.querySelector(a.getAttribute('href'));
      if(t){ e.preventDefault(); t.scrollIntoView({ behavior:'smooth', block:'start' }); }
    });
  });

  /* ── Chatbot IA (relais n8n / Claude) ── */
  function createChatbot(msgId, inputId, sendId, fileId){
    const msgs  = document.getElementById(msgId);
    const input = document.getElementById(inputId);
    const send  = document.getElementById(sendId);
    const fileInput = fileId ? document.getElementById(fileId) : null;
    if(!msgs||!input||!send) return;

    const sessionId = Math.random().toString(36).slice(2);
    let history = [];
    let busy    = false;
    let pendingFile = null;

    const addMsg=(text,type)=>{
      const d=document.createElement('div');
      d.className=`pbzh-msg pbzh-msg-${type}`;
      const b=document.createElement('div');
      b.className='pbzh-msg-bubble';
      b.textContent=text;
      d.appendChild(b);
      msgs.appendChild(d);
      msgs.scrollTop=msgs.scrollHeight;
    };

    const showTyping=()=>{
      const d=document.createElement('div');
      d.className='pbzh-typing'; d.id=msgId+'-typing';
      d.innerHTML='<span></span><span></span><span></span>';
      msgs.appendChild(d); msgs.scrollTop=msgs.scrollHeight;
    };
    const hideTyping=()=>{ document.getElementById(msgId+'-typing')?.remove(); };

    const readFile=(file)=> new Promise((resolve)=>{
      const reader = new FileReader();
      reader.onload = e => resolve({ name: file.name, type: file.type, data: e.target.result.split(',')[1] });
      reader.readAsDataURL(file);
    });

    const askBot=async(userMsg, fileData)=>{
      busy=true; send.disabled=true; showTyping();
      if(userMsg) history.push({ role:'user', content:userMsg });
      try {
        const payload = { message: userMsg||'', history, session_id: sessionId };
        if(fileData) payload.file = fileData;
        const res  = await fetch(N8N_CHAT_WEBHOOK, {
          method:'POST',
          headers:{'Content-Type':'application/json'},
          body: JSON.stringify(payload)
        });
        const rawData = await res.json();
        const data = Array.isArray(rawData) ? rawData[0] : rawData;
        const reply = data.reply || data.message || "Je n'ai pas pu traiter votre demande, réessayez.";
        hideTyping();
        addMsg(reply,'bot');
        history.push({ role:'assistant', content:reply });
        if(data.done){ send.disabled=true; input.disabled=true; input.placeholder='Conversation terminée'; }
        else { busy=false; send.disabled=!input.value.trim(); }
      } catch(e){
        hideTyping();
        addMsg("Connexion impossible. Contactez-nous directement : 06 69 90 30 24",'bot');
        busy=false; send.disabled=!input.value.trim();
      }
    };

    const doSend=async()=>{
      let txt = input.value.trim();
      if(!txt && !pendingFile) return;
      if(!txt && pendingFile) txt = 'Voici mon fichier visuel.';
      let displayMsg = txt;
      if(pendingFile) displayMsg += (txt ? ' ' : '') + '📎 ' + pendingFile.name;
      addMsg(displayMsg,'user');
      input.value=''; send.disabled=true;
      const fileData = pendingFile ? await readFile(pendingFile) : null;
      pendingFile = null;
      if(fileInput){ fileInput.value=''; }
      askBot(txt, fileData);
    };

    if(fileInput){
      fileInput.addEventListener('change',()=>{
        if(fileInput.files[0]){
          pendingFile = fileInput.files[0];
          send.disabled = false;
          input.placeholder = '📎 ' + pendingFile.name + ' – Ajoutez un message ou envoyez';
        }
      });
    }

    setTimeout(()=> askBot(''), 400);
    input.addEventListener('input',()=>{ if(!busy) send.disabled=(!input.value.trim() && !pendingFile); });
    input.addEventListener('keydown',e=>{ if(e.key==='Enter') doSend(); });
    send.addEventListener('click', doSend);
  }

  createChatbot('pbzh-chat-messages-embedded','pbzh-chat-input-embedded','pbzh-chat-send-embedded','pbzh-chat-file-embedded');
  createChatbot('pbzh-chat-messages-widget',  'pbzh-chat-input-widget',  'pbzh-chat-send-widget',  'pbzh-chat-file-widget');

  /* ── Chat widget toggle ── */
  const widget = document.getElementById('pbzh-chat-widget');
  const unread = document.getElementById('pbzh-chat-unread');
  document.getElementById('pbzh-chat-toggle')?.addEventListener('click',()=>{
    widget.classList.toggle('pbzh-chat-widget-open');
    if(widget.classList.contains('pbzh-chat-widget-open')) unread.style.display='none';
  });

})();
</script>

